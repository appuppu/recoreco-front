rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper Functions
    // ========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      return isAuthenticated() &&
             request.resource.data.keys().hasAll(['username', 'email', 'displayName', 'isPublic', 'createdAt', 'updatedAt', 'followingCount', 'followerCount', 'postCount']);
    }

    function isValidPost() {
      return isAuthenticated() &&
             request.resource.data.userId is string &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    // ========================================
    // Users Collection
    // ========================================

    match /users/{userId} {
      // Anyone can read user profiles (including unauthenticated users)
      allow read: if true;

      // Users can create their own profile
      allow create: if isOwner(userId) && isValidUser();

      // Users can update their own profile
      allow update: if isOwner(userId) &&
                       // Can only update specific fields
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'profileImageUrl', 'bio', 'isPublic', 'updatedAt', 'followingCount', 'followerCount', 'postCount']);

      // 他ユーザーをフォロー/解除したとき、相手の followerCount のみ更新できる
      // （フォロー処理のバッチで相手ドキュメントの followerCount を increment するため）
      allow update: if isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['followerCount']);

      // Users can delete their own profile
      allow delete: if isOwner(userId);

      // ========================================
      // Followers Subcollection
      // ========================================
      match /followers/{followerId} {
        // Anyone can read followers list
        allow read: if isAuthenticated();

        // Anyone can add/remove followers (managed by app logic)
        allow write: if isAuthenticated();
      }

      // ========================================
      // Following Subcollection (users)
      // ========================================
      match /following/{followingId} {
        // Anyone can read following list
        allow read: if isAuthenticated();

        // Anyone can add/remove following (managed by app logic)
        allow write: if isAuthenticated();
      }

      // ========================================
      // Following Channels Subcollection
      // ========================================
      match /followingChannels/{channelId} {
        // Anyone can read following channels list
        allow read: if isAuthenticated();

        // Anyone can add/remove following channels (managed by app logic)
        allow write: if isAuthenticated();
      }

      // ========================================
      // Read Posts Subcollection (for unread tracking)
      // ========================================
      match /readPosts/{postId} {
        // Users can read their own read posts
        allow read: if isOwner(userId);

        // Users can mark posts as read
        allow create: if isOwner(userId);

        // No update or delete (create only)
        allow update, delete: if false;
      }
    }

    // ========================================
    // Posts Collection
    // ========================================

    match /posts/{postId} {
      // Anyone can read posts (including unauthenticated users for discovery feed)
      allow read: if true;

      // Users can create posts
      // channelId is optional (posts are no longer tied to channels)
      allow create: if isAuthenticated() &&
                       isValidPost() &&
                       request.resource.data.userId == request.auth.uid;

      // Users can update their own posts (comment only)
      allow update: if isAuthenticated() &&
                       isOwner(resource.data.userId) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['comment', 'updatedAt']);

      // Anyone can update like/comment counts
      allow update: if isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likeCount', 'commentCount']);

      // Users can delete their own posts OR channel owner can delete posts in their channel
      allow delete: if isAuthenticated() &&
                       (isOwner(resource.data.userId) ||
                        // Channel owner can delete any post in their channel
                        ('channelId' in resource.data &&
                         resource.data.channelId is string &&
                         resource.data.channelId.size() > 0 &&
                         isOwner(get(/databases/$(database)/documents/channels/$(resource.data.channelId)).data.userId)));

      // ========================================
      // Likes Subcollection
      // ========================================
      match /likes/{userId} {
        // Anyone can read likes
        allow read: if isAuthenticated();

        // Users can like posts (their own userId)
        allow create: if isAuthenticated() && isOwner(userId);

        // Users can unlike posts (their own userId)
        allow delete: if isAuthenticated() && isOwner(userId);

        // No update
        allow update: if false;
      }

      // ========================================
      // Comments Subcollection
      // ========================================
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if isAuthenticated();

        // Users can create comments
        allow create: if isAuthenticated() &&
                         request.resource.data.userId == request.auth.uid;

        // Users can update their own comments
        allow update: if isAuthenticated() &&
                         isOwner(resource.data.userId) &&
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['content', 'updatedAt']);

        // Users can delete their own comments OR post owner can delete any comment
        allow delete: if isAuthenticated() &&
                         (isOwner(resource.data.userId) ||
                          isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.userId));
      }
    }

    // ========================================
    // Notifications Collection
    // ========================================

    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && isOwner(resource.data.recipientId);

      // Anyone can create notifications (managed by app logic)
      allow create: if isAuthenticated();

      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() &&
                       isOwner(resource.data.recipientId) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['isRead']);

      // Users can delete their own notifications
      allow delete: if isAuthenticated() && isOwner(resource.data.recipientId);
    }

    // ========================================
    // Blocks Collection
    // ========================================

    match /blocks/{blockId} {
      // Users can read their own blocks
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data.blockerId) || isOwner(resource.data.blockedId));

      // Users can block other users
      allow create: if isAuthenticated() &&
                       request.resource.data.blockerId == request.auth.uid;

      // Users can unblock (delete their own blocks)
      allow delete: if isAuthenticated() && isOwner(resource.data.blockerId);

      // No update
      allow update: if false;
    }

    // ========================================
    // Reports Collection (Admin only in production)
    // ========================================

    match /reports/{reportId} {
      // No read access for regular users (admin only)
      allow read: if false;

      // Users can create reports
      allow create: if isAuthenticated() &&
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.status == 'pending';

      // No update or delete for regular users (admin only)
      allow update, delete: if false;
    }

    // ========================================
    // Channels Collection
    // ========================================

    match /channels/{channelId} {
      // Anyone can read channels (including unauthenticated users for discovery)
      allow read: if true;

      // Users can create their own channels
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'name', 'createdAt', 'updatedAt', 'channelType', 'accessType']) &&
                       request.resource.data.channelType in ['personal', 'shared'] &&
                       request.resource.data.accessType in ['public', 'private'];

      // Users can update their own channels
      allow update: if isAuthenticated() &&
                       isOwner(resource.data.userId) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['name', 'updatedAt', 'latestPostId', 'latestPostAt', 'latestPostArtworkUrl', 'channelType', 'accessType']);

      // Users can delete their own channels
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);

      // ========================================
      // Channel Followers Subcollection
      // ========================================
      match /followers/{followerId} {
        // Anyone can read channel followers
        allow read: if isAuthenticated();

        // Users can follow channels
        allow create: if isAuthenticated();

        // Channel owner can delete followers when deleting channel
        allow delete: if isAuthenticated() &&
                         (isOwner(followerId) ||
                          isOwner(get(/databases/$(database)/documents/channels/$(channelId)).data.userId));

        // No update
        allow update: if false;
      }
    }

    // ========================================
    // Channel Follows Collection
    // ========================================

    match /channelFollows/{channelId} {
      // Anyone can read channel follows
      allow read: if isAuthenticated();

      // Allow creating/deleting the channel follows document
      allow create, delete: if isAuthenticated();

      // No update
      allow update: if false;

      // ========================================
      // Followers Subcollection (under channelFollows)
      // ========================================
      match /followers/{followerId} {
        // Anyone can read followers
        allow read: if isAuthenticated();

        // Users can follow/unfollow (only their own userId)
        allow create: if isAuthenticated() && isOwner(followerId);
        allow delete: if isAuthenticated() && isOwner(followerId);

        // No update
        allow update: if false;
      }
    }

    // ========================================
    // Config Collection (アプリ設定: 強制アップデートの最低バージョン等)
    // ========================================
    match /config/{document} {
      // 誰でも読める（未ログイン・起動直後にバージョンチェックするため）
      allow read: if true;
      // 書き込みはアプリからは不可（コンソールから管理者が手動更新）
      allow write: if false;
    }

    // ========================================
    // Default: Deny all other access
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
